# RTCCM Customer Secrets Template
# Copy to .secrets.env and edit values:
#   cp secrets-template.env .secrets.env
#   chmod 600 .secrets.env
#
# This file contains PASSWORDS and KEYS — keep it out of version control.
# The .gitignore in this repo already excludes .secrets.env.
#
# File-based secrets (TLS keys, cloud SA JSON, license tokens) live in the
# secrets/ directory instead — see README.md for the full list.

# ─── Postgres ───────────────────────────────────────────────────────────────
# Also mirror this value into secrets/postgres_password.txt (the compose file
# reads the file form via POSTGRES_PASSWORD_FILE).
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=CHANGEME_postgres_password

# ─── ClickHouse ─────────────────────────────────────────────────────────────
# Also mirror this into secrets/clickhouse_password.txt for Grafana.
# Generate with: openssl rand -hex 16
CLICKHOUSE_USER=rtccm
CLICKHOUSE_PASSWORD=CHANGEME_clickhouse_password

# ─── ClickHouse encryption key (at-rest encryption) ─────────────────────────
# 32-byte key, hex-encoded. Generate with: openssl rand -hex 32
# Mirror into secrets/clickhouse_encryption_key.bin as raw bytes.
CLICKHOUSE_ENCRYPTION_KEY=CHANGEME_64_hex_chars

# ─── RTCCM admin bootstrap ──────────────────────────────────────────────────
# Optional pre-shared key for the first admin account creation.
# Leave blank to use the UI-based admin setup flow on first visit.
RTCCM_ADMIN_KEY=

# ─── Infracost API (optional) ───────────────────────────────────────────────
# Sign up at infracost.io for a free API key. Leaves pricing sidecar running
# in offline mode if blank.
INFRACOST_API_KEY=

# ─── Azure credentials (optional, only for --profile azure) ────────────────
# Mirror values from .env here if you prefer to keep them out of the non-secret
# .env file. Either location works.
# RTCCM_AZURE_CLIENT_SECRET=
